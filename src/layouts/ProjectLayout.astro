---
import PageLayout from './PageLayout.astro';
import { getCollection } from 'astro:content';
import BlogCard from '../components/blog/BlogCard.astro';

interface Props {
  title: string;
  shortTitle: string;
  description: string;
  icon: string;
  color: string;
  slug: string;
}

const { title, shortTitle, description, icon, color, slug } = Astro.props;

// Get related blog posts
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const relatedPosts = allPosts
  .filter((post) => post.data.project === slug || post.data.tags.includes(slug))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<PageLayout title={title} description={description}>
  <div class="mx-auto max-w-5xl px-4 sm:px-6 py-12">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 text-sm text-text-muted dark:text-text-muted-dark mb-8" aria-label="Breadcrumb">
      <a href="/" class="hover:text-accent transition-colors">Хирахмо</a>
      <span>/</span>
      <a href="/projects/" class="hover:text-accent transition-colors">Проекты</a>
      <span>/</span>
      <span class="text-text dark:text-text-dark">{shortTitle}</span>
    </nav>

    <!-- Project header -->
    <header class="mb-12" data-animate>
      <div class="flex items-center gap-4 mb-4">
        <div
          class="w-14 h-14 rounded-xl flex items-center justify-center text-2xl"
          style={`background-color: ${color}20; color: ${color};`}
        >
          {icon}
        </div>
        <div>
          <h1 class="text-3xl sm:text-4xl font-bold tracking-tight">{title}</h1>
        </div>
      </div>
      <p class="text-lg text-text-muted dark:text-text-muted-dark max-w-2xl">{description}</p>
    </header>

    <!-- Project content (from MD) -->
    <div class="prose mb-16" data-animate>
      <slot />
    </div>

    <!-- Related posts -->
    {relatedPosts.length > 0 && (
      <section data-animate>
        <h2 class="text-2xl font-bold mb-6">Записи по теме</h2>
        <div class="grid gap-6 sm:grid-cols-2">
          {relatedPosts.map((post, i) => (
            <div data-animate data-animate-delay={String(i + 1)}>
              <BlogCard post={post} />
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Back -->
    <div class="mt-16 pt-8 border-t border-border dark:border-border-dark">
      <a
        href="/projects/"
        class="inline-flex items-center gap-2 text-sm text-text-muted dark:text-text-muted-dark hover:text-accent transition-colors"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Все проекты
      </a>
    </div>
  </div>
</PageLayout>
