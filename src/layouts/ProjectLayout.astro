---
import PageLayout from './PageLayout.astro';
import { getCollection } from 'astro:content';
import BlogCard from '../components/blog/BlogCard.astro';

interface Props {
  title: string;
  shortTitle: string;
  description: string;
  icon: string;
  color: string;
  slug: string;
}

const { title, shortTitle, description, icon, color, slug } = Astro.props;

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const relatedPosts = allPosts
  .filter((post) => post.data.project === slug || post.data.tags.includes(slug))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<PageLayout title={title} description={description}>
  <div class="mx-auto max-w-3xl px-4 sm:px-6 py-16">
    <header class="mb-12" data-animate>
      <div class="flex items-center gap-3 mb-4">
        <div class="w-2.5 h-2.5 rounded-full" style={`background-color: ${color};`}></div>
        <p class="text-sm text-text-muted dark:text-text-muted-dark">{shortTitle}</p>
      </div>
      <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight mb-3">{title}</h1>
      <p class="text-[15px] text-text-secondary dark:text-text-secondary-dark">{description}</p>
    </header>

    <div class="prose mb-16" data-animate>
      <slot />
    </div>

    {relatedPosts.length > 0 && (
      <section data-animate>
        <h2 class="text-lg font-semibold mb-6">Записи по теме</h2>
        {relatedPosts.map((post) => (
          <BlogCard post={post} />
        ))}
      </section>
    )}

    <div class="mt-16 pt-8 border-t border-border dark:border-border-dark">
      <a
        href="/projects/"
        class="inline-flex items-center gap-2 text-[13px] text-text-muted dark:text-text-muted-dark hover:text-text dark:hover:text-text-dark transition-colors"
      >
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Все проекты
      </a>
    </div>
  </div>
</PageLayout>
