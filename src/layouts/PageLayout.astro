---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedDate?: Date;
  updatedDate?: Date;
}

const { title, description, image, type, publishedDate, updatedDate } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  type={type}
  publishedDate={publishedDate}
  updatedDate={updatedDate}
>
  <Header />
  <main class="pt-16">
    <slot />
  </main>
  <Footer />
</BaseLayout>
