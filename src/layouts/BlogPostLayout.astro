---
import PageLayout from './PageLayout.astro';
import { formatDate } from '../utils/formatDate';
import { getReadingTime } from '../utils/readingTime';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags?: string[];
  body: string;
}

const { title, description, pubDate, updatedDate, heroImage, tags = [], body } = Astro.props;
const readingTime = getReadingTime(body);
---

<PageLayout title={title} description={description} type="article" publishedDate={pubDate} updatedDate={updatedDate}>
  <article class="mx-auto max-w-3xl px-4 sm:px-6 py-16">
    <header class="mb-12" data-animate>
      {heroImage && (
        <img
          src={heroImage}
          alt={title}
          class="w-full rounded-lg mb-10 object-cover max-h-96"
          transition:name={`hero-${Astro.url.pathname}`}
        />
      )}

      <div class="flex items-center gap-3 text-[13px] text-text-muted dark:text-text-muted-dark mb-4">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        <span>&middot;</span>
        <span>{readingTime} чтения</span>
        {updatedDate && (
          <>
            <span>&middot;</span>
            <span>обновлено {formatDate(updatedDate)}</span>
          </>
        )}
      </div>

      <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight leading-tight mb-4">{title}</h1>

      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => (
            <a
              href={`/tags/${tag}/`}
              class="text-[12px] text-text-muted dark:text-text-muted-dark hover:text-text dark:hover:text-text-dark transition-colors"
            >
              #{tag}
            </a>
          ))}
        </div>
      )}
    </header>

    <div class="prose" data-animate>
      <slot />
    </div>

    <div class="mt-16 pt-8 border-t border-border dark:border-border-dark">
      <a
        href="/blog/"
        class="inline-flex items-center gap-2 text-[13px] text-text-muted dark:text-text-muted-dark hover:text-text dark:hover:text-text-dark transition-colors"
      >
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Все записи
      </a>
    </div>
  </article>
</PageLayout>
