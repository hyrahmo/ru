---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="404 — Страница не найдена">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 py-24 text-center">
    <div data-animate>
      <h1 class="text-7xl font-bold text-accent mb-4">404</h1>
      <p class="text-xl text-text-muted dark:text-text-muted-dark mb-8">
        Страница не найдена
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-accent text-white font-medium hover:bg-accent-hover transition-colors"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        На главную
      </a>
    </div>
  </div>
</PageLayout>
