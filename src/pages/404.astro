---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="404">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 py-32 text-center">
    <div data-animate>
      <p class="text-sm font-medium tracking-widest uppercase text-text-muted dark:text-text-muted-dark mb-4">404</p>
      <h1 class="text-2xl font-semibold tracking-tight mb-3">Страница не найдена</h1>
      <p class="text-[15px] text-text-secondary dark:text-text-secondary-dark mb-8">
        Возможно, страница была перемещена или удалена.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 text-sm text-text-muted dark:text-text-muted-dark hover:text-text dark:hover:text-text-dark transition-colors"
      >
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        На главную
      </a>
    </div>
  </div>
</PageLayout>
