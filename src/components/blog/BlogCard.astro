---
import { formatDate } from '../../utils/formatDate';
import { getReadingTime } from '../../utils/readingTime';

interface Props {
  post: {
    id: string;
    data: {
      title: string;
      description: string;
      pubDate: Date;
      tags: string[];
      heroImage?: string;
    };
    body?: string;
  };
}

const { post } = Astro.props;
const readingTime = post.body ? getReadingTime(post.body) : null;
---

<a
  href={`/blog/${post.id}/`}
  class="group block py-5 border-b border-border dark:border-border-dark last:border-b-0 transition-colors"
>
  <div class="flex items-baseline gap-4 mb-1.5">
    <time
      datetime={post.data.pubDate.toISOString()}
      class="text-[13px] text-text-muted dark:text-text-muted-dark tabular-nums shrink-0"
    >
      {formatDate(post.data.pubDate)}
    </time>
    {readingTime && (
      <span class="text-[13px] text-text-muted dark:text-text-muted-dark hidden sm:inline">
        {readingTime}
      </span>
    )}
  </div>
  <h3 class="text-[15px] font-medium mb-1 group-hover:text-link dark:group-hover:text-link-dark transition-colors">
    {post.data.title}
  </h3>
  <p class="text-[13px] text-text-secondary dark:text-text-secondary-dark line-clamp-2">
    {post.data.description}
  </p>
</a>
