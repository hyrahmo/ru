---
interface Props {
  title: string;
  shortTitle: string;
  description: string;
  icon: string;
  color: string;
  slug: string;
  status?: 'active' | 'planned' | 'paused';
}

const { title, shortTitle, description, icon, color, slug, status = 'active' } = Astro.props;
---

<a
  href={`/projects/${slug}/`}
  class="group relative block p-5 rounded-lg border border-border dark:border-border-dark hover:border-text/20 dark:hover:border-text-dark/20 transition-all duration-200 bg-surface dark:bg-surface-dark"
>
  <div class="flex items-center gap-3 mb-2.5">
    <div
      class="w-2 h-2 rounded-full shrink-0"
      style={`background-color: ${color};`}
    ></div>
    <h3 class="text-sm font-medium group-hover:text-link dark:group-hover:text-link-dark transition-colors">
      {shortTitle}
    </h3>
    {status === 'planned' && (
      <span class="text-[10px] text-text-muted dark:text-text-muted-dark">
        скоро
      </span>
    )}
  </div>
  <p class="text-[13px] leading-relaxed text-text-secondary dark:text-text-secondary-dark pl-5">
    {description}
  </p>
</a>
