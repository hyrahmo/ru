---
interface Props {
  title: string;
  shortTitle: string;
  description: string;
  icon: string;
  color: string;
  slug: string;
  status?: 'active' | 'planned' | 'paused';
}

const { title, shortTitle, description, icon, color, slug, status = 'active' } = Astro.props;
---

<a
  href={`/projects/${slug}/`}
  class="group block p-6 rounded-2xl border border-border dark:border-border-dark hover:border-transparent hover:shadow-xl dark:hover:shadow-2xl transition-all duration-300 hover:scale-[1.02] bg-surface dark:bg-surface-dark"
>
  <div class="flex items-start gap-4">
    <div
      class="w-12 h-12 rounded-xl flex items-center justify-center text-xl shrink-0 transition-transform duration-300 group-hover:scale-110"
      style={`background-color: ${color}20; color: ${color};`}
    >
      {icon}
    </div>
    <div class="min-w-0">
      <div class="flex items-center gap-2 mb-1">
        <h3 class="font-semibold text-lg truncate group-hover:text-accent transition-colors">
          {shortTitle}
        </h3>
        {status === 'planned' && (
          <span class="px-2 py-0.5 text-[10px] font-medium rounded-full bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400">
            скоро
          </span>
        )}
      </div>
      <p class="text-sm text-text-muted dark:text-text-muted-dark line-clamp-2">{description}</p>
    </div>
  </div>
</a>
