---
import { getCollection } from 'astro:content';
import ProjectCard from '../projects/ProjectCard.astro';

const projects = await getCollection('projects');
const sortedProjects = projects.sort((a, b) => a.data.order - b.data.order);
---

<section class="py-20">
  <div class="mx-auto max-w-3xl px-4 sm:px-6">
    <div class="flex items-baseline justify-between mb-10" data-animate>
      <h2 class="text-lg font-semibold tracking-tight">Проекты</h2>
      <a href="/projects/" class="text-[13px] text-text-muted dark:text-text-muted-dark hover:text-text dark:hover:text-text-dark transition-colors">
        Все &rarr;
      </a>
    </div>
    <div class="grid gap-3 sm:grid-cols-2">
      {sortedProjects.map((project, i) => (
        <div data-animate data-animate-delay={String((i % 6) + 1)}>
          <ProjectCard
            title={project.data.title}
            shortTitle={project.data.shortTitle}
            description={project.data.description}
            icon={project.data.icon}
            color={project.data.color}
            slug={project.id}
            status={project.data.status}
          />
        </div>
      ))}
    </div>
  </div>
</section>
