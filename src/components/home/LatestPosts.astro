---
import { getCollection } from 'astro:content';
import BlogCard from '../blog/BlogCard.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

{latestPosts.length > 0 && (
  <section class="py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <div class="flex items-baseline justify-between mb-10" data-animate>
        <h2 class="text-lg font-semibold tracking-tight">Записи</h2>
        <a href="/blog/" class="text-[13px] text-text-muted dark:text-text-muted-dark hover:text-text dark:hover:text-text-dark transition-colors">
          Все &rarr;
        </a>
      </div>
      <div data-animate>
        {latestPosts.map((post) => (
          <BlogCard post={post} />
        ))}
      </div>
    </div>
  </section>
)}
