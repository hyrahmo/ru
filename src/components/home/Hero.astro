---
import { SITE } from '../../data/site';
---

<section class="relative overflow-hidden py-24 sm:py-32">
  <!-- Background gradient orbs -->
  <div class="absolute inset-0 -z-10 overflow-hidden">
    <div class="absolute -top-40 -right-40 w-80 h-80 rounded-full bg-accent/10 blur-3xl"></div>
    <div class="absolute -bottom-40 -left-40 w-80 h-80 rounded-full bg-accent/5 blur-3xl"></div>
  </div>

  <div class="mx-auto max-w-5xl px-4 sm:px-6 text-center">
    <div data-animate>
      <h1 class="text-5xl sm:text-7xl font-bold tracking-tight mb-6">
        <span class="inline-block bg-gradient-to-r from-accent via-blue-400 to-accent bg-[length:200%_auto] bg-clip-text text-transparent animate-shimmer">
          Хирахмо
        </span>
      </h1>
      <p class="text-lg sm:text-xl text-text-muted dark:text-text-muted-dark max-w-2xl mx-auto mb-10">
        {SITE.description}
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a
          href="/projects/"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-accent text-white font-medium hover:bg-accent-hover transition-colors shadow-lg shadow-accent/25"
        >
          Проекты
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
        <a
          href="/blog/"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-border dark:border-border-dark font-medium hover:bg-border dark:hover:bg-border-dark transition-colors"
        >
          Блог
        </a>
      </div>
    </div>
  </div>
</section>
