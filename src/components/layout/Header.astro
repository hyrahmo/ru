---
import { navigation } from '../../data/navigation';
import ThemeToggle from './ThemeToggle.astro';
---

<header id="header" class="fixed top-0 left-0 right-0 z-50 transition-[background-color,border-color,backdrop-filter] duration-300">
  <div class="mx-auto max-w-3xl px-4 sm:px-6">
    <div class="flex items-center justify-between h-14">
      <!-- Logo -->
      <a href="/" class="text-sm font-semibold tracking-tight">
        хирахмо
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-0.5">
        {navigation.map((item) => (
          <a
            href={item.href}
            class:list={[
              'px-3 py-1.5 rounded-md text-[13px] transition-colors',
              Astro.url.pathname === item.href || (item.href !== '/' && Astro.url.pathname.startsWith(item.href))
                ? 'text-text dark:text-text-dark font-medium'
                : 'text-text-muted dark:text-text-muted-dark hover:text-text dark:hover:text-text-dark',
            ]}
          >
            {item.label}
          </a>
        ))}
        <div class="ml-1">
          <ThemeToggle />
        </div>
      </nav>

      <!-- Mobile -->
      <div class="flex items-center gap-1.5 md:hidden">
        <ThemeToggle />
        <button
          id="mobile-menu-btn"
          aria-label="Меню"
          class="p-1.5 rounded-md hover:bg-border/50 dark:hover:bg-border-dark/50 transition-colors cursor-pointer"
        >
          <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-4 border-t border-border dark:border-border-dark mt-1 pt-3">
      <nav class="flex flex-col gap-0.5">
        {navigation.map((item) => (
          <a
            href={item.href}
            class:list={[
              'px-3 py-2 rounded-md text-[13px] transition-colors',
              Astro.url.pathname === item.href || (item.href !== '/' && Astro.url.pathname.startsWith(item.href))
                ? 'text-text dark:text-text-dark font-medium'
                : 'text-text-muted dark:text-text-muted-dark hover:text-text dark:hover:text-text-dark',
            ]}
          >
            {item.label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</header>

<script>
  function initHeader() {
    const header = document.getElementById('header');
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    if (!header || !menuBtn || !mobileMenu) return;

    const onScroll = () => {
      if (window.scrollY > 8) {
        header.style.backgroundColor = '';
        header.classList.add('header-scrolled');
      } else {
        header.classList.remove('header-scrolled');
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    menuBtn.addEventListener('click', () => mobileMenu.classList.toggle('hidden'));
    mobileMenu.querySelectorAll('a').forEach((link) =>
      link.addEventListener('click', () => mobileMenu.classList.add('hidden'))
    );
  }

  initHeader();
  document.addEventListener('astro:after-swap', initHeader);
</script>

<style>
  .header-scrolled {
    backdrop-filter: blur(12px) saturate(180%);
    -webkit-backdrop-filter: blur(12px) saturate(180%);
    background-color: rgb(245 245 244 / 0.8);
    border-bottom: 1px solid rgb(228 228 231 / 0.6);
  }

  :global(.dark) .header-scrolled {
    background-color: rgb(9 9 11 / 0.8);
    border-bottom-color: rgb(31 31 35 / 0.6);
  }
</style>
