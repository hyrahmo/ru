---
import { Icon } from 'astro-icon/components';
import { socials } from '../../data/social';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<div class:list={['flex items-center gap-1', className]}>
  {socials.map((social) => (
    <a
      href={social.url}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={social.name}
      class="p-1.5 rounded-md text-text-muted dark:text-text-muted-dark hover:text-text dark:hover:text-text-dark transition-colors"
    >
      <Icon name={social.icon} class="w-4 h-4" />
    </a>
  ))}
</div>
