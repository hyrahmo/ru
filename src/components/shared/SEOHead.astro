---
import { SITE } from '../../data/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedDate?: Date;
  updatedDate?: Date;
  noindex?: boolean;
}

const {
  title,
  description = SITE.description,
  image = SITE.ogImage,
  type = 'website',
  publishedDate,
  updatedDate,
  noindex = false,
} = Astro.props;

const pageTitle = title ? `${title} — ${SITE.title}` : SITE.title;
const canonicalURL = new URL(Astro.url.pathname, SITE.url);
const ogImageURL = new URL(image, SITE.url);
---

<title>{pageTitle}</title>
<meta name="description" content={description} />
{noindex && <meta name="robots" content="noindex, nofollow" />}
<link rel="canonical" href={canonicalURL.href} />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL.href} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageURL.href} />
<meta property="og:locale" content="ru_RU" />
<meta property="og:site_name" content={SITE.title} />

{publishedDate && (
  <meta property="article:published_time" content={publishedDate.toISOString()} />
)}
{updatedDate && (
  <meta property="article:modified_time" content={updatedDate.toISOString()} />
)}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL.href} />

<!-- JSON-LD -->
{type === 'website' ? (
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE.title,
    alternateName: 'hyrahmo',
    url: SITE.url,
    inLanguage: 'ru',
    author: {
      '@type': 'Person',
      name: SITE.author,
      url: SITE.url,
    },
  })} />
) : (
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: title,
    description,
    image: ogImageURL.href,
    datePublished: publishedDate?.toISOString(),
    dateModified: updatedDate?.toISOString() ?? publishedDate?.toISOString(),
    author: {
      '@type': 'Person',
      name: SITE.author,
      url: SITE.url,
    },
    publisher: {
      '@type': 'Organization',
      name: SITE.title,
      url: SITE.url,
    },
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': canonicalURL.href,
    },
  })} />
)}
